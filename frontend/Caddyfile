:80 {
	root * /srv
	encode gzip zstd

	@api path /api/* /socket.io/*
	handle @api {
		reverse_proxy wire-backend:3003
	}

	@assets path /assets/*
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		header Cache-Control "no-store, no-cache, must-revalidate"
		try_files {path} /index.html
		file_server
	}
}
