generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  gateId    String    @unique @map("gate_id")
  username  String    @unique
  email     String    @unique
  groups    String[]  @default([])
  createdAt DateTime  @default(now()) @map("created_at")

  memberships       RoomMember[]
  messages          Message[]
  requestsSent      ConversationRequest[] @relation("RequestsSent")
  requestsReceived  ConversationRequest[] @relation("RequestsReceived")

  @@map("users")
}

model Room {
  id        String   @id @default(uuid())
  name      String
  type      String         @default("group") @map("type")
  isDirect  Boolean  @default(false) @map("is_direct")
  createdAt DateTime @default(now()) @map("created_at")

  members  RoomMember[]
  messages Message[]

  @@map("rooms")
}

model RoomMember {
  roomId   String         @map("room_id")
  userId   String         @map("user_id")
  role     RoomMemberRole @default(MEMBER)
  canWrite    Boolean        @default(true) @map("can_write")
  unreadCount Int    @default(0) @map("unread_count")
  joinedAt DateTime       @default(now()) @map("joined_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@map("room_members")
}

enum RoomMemberRole {
  OWNER
  MEMBER
}

model Message {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@map("messages")
}

model ConversationRequest {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  fromUser User @relation("RequestsSent", fields: [fromUserId], references: [id])
  toUser   User @relation("RequestsReceived", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId])
  @@map("conversation_requests")
}
